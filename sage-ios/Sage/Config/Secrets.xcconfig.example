// Secrets.xcconfig.example — 模板（入 git，新成员复制后填真实值）
//
// 使用方法：
//   cp sage-ios/Sage/Config/Secrets.xcconfig.example \
//      sage-ios/Sage/Config/Secrets.xcconfig
//   然后填入下方占位字段的真实值
//
// 真实 anon key 见：
//   - Supabase Dashboard → Project Settings → API → Project API keys → anon public
//   - 或问已经在做 iOS 端的同事

// xcconfig 解析坑：URL 中的 `//` 必须写作 `/$()/`（不然会被当注释起点）

SUPABASE_URL = https:/$()/your-project-ref.supabase.co
SUPABASE_ANON_KEY = your-anon-key-here

// Railway 后端 Bearer 鉴权 token（对应 Railway env SAGE_API_TOKEN）
SAGE_API_TOKEN = your-sage-api-token-here
